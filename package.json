{
  "name": "markdown-multiverse-terminal-copy",
  "displayName": "Markdown Multiverse - Terminal Copy Tool",
  "description": "Right-click in the terminal to copy selected output as Clean, Markdown, Slack, Telegram, Discord, or HTML. Strips ANSI, resolves carriage-return overwrites and backspace overprinting, detects tables, and formats for each destination.",
  "version": "0.3.0",
  "publisher": "geilt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/geilt/markdown-multiverse-terminal-copy.git"
  },
  "bugs": {
    "url": "https://github.com/geilt/markdown-multiverse-terminal-copy/issues"
  },
  "homepage": "https://github.com/geilt/markdown-multiverse-terminal-copy#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "keywords": [
    "terminal",
    "clipboard",
    "copy",
    "ansi",
    "markdown",
    "slack",
    "discord",
    "telegram",
    "html"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownMultiverse.copyClean",
        "title": "Copy as Clean",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.copyMarkdown",
        "title": "Copy as Markdown",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.copySlack",
        "title": "Copy as Slack",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.copyTelegram",
        "title": "Copy as Telegram",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.copyDiscord",
        "title": "Copy as Discord",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.copyHtml",
        "title": "Copy as HTML",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.editorCopySlack",
        "title": "Copy Markdown as Slack",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.editorCopyDiscord",
        "title": "Copy Markdown as Discord",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.editorCopyTelegram",
        "title": "Copy Markdown as Telegram",
        "category": "Markdown Multiverse"
      },
      {
        "command": "markdownMultiverse.editorCopyHtml",
        "title": "Copy Markdown as HTML",
        "category": "Markdown Multiverse"
      }
    ],
    "submenus": [
      {
        "id": "markdownMultiverse.copyAs",
        "label": "Copy As"
      },
      {
        "id": "markdownMultiverse.editorCopyAs",
        "label": "Copy As"
      }
    ],
    "menus": {
      "terminal/context": [
        {
          "submenu": "markdownMultiverse.copyAs",
          "group": "3_edit@10"
        }
      ],
      "editor/context": [
        {
          "submenu": "markdownMultiverse.editorCopyAs",
          "group": "9_cutcopypaste@10",
          "when": "editorLangId == markdown"
        }
      ],
      "markdownMultiverse.copyAs": [
        {
          "command": "markdownMultiverse.copyClean",
          "group": "1_formats@1"
        },
        {
          "command": "markdownMultiverse.copyMarkdown",
          "group": "1_formats@2"
        },
        {
          "command": "markdownMultiverse.copySlack",
          "group": "1_formats@3"
        },
        {
          "command": "markdownMultiverse.copyDiscord",
          "group": "1_formats@4"
        },
        {
          "command": "markdownMultiverse.copyTelegram",
          "group": "1_formats@5"
        },
        {
          "command": "markdownMultiverse.copyHtml",
          "group": "1_formats@6"
        }
      ],
      "markdownMultiverse.editorCopyAs": [
        {
          "command": "markdownMultiverse.editorCopySlack",
          "group": "1_formats@1"
        },
        {
          "command": "markdownMultiverse.editorCopyDiscord",
          "group": "1_formats@2"
        },
        {
          "command": "markdownMultiverse.editorCopyTelegram",
          "group": "1_formats@3"
        },
        {
          "command": "markdownMultiverse.editorCopyHtml",
          "group": "1_formats@4"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Multiverse",
      "properties": {
        "markdownMultiverse.stripPrompts": {
          "type": "boolean",
          "default": false,
          "description": "Strip common shell prompt prefixes (user@host:~$, PS C:\\>, >>>, $). Destructive — may remove non-prompt content that matches these patterns."
        },
        "markdownMultiverse.tabWidth": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces to substitute for tab characters."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test --import tsx 'src/test/**/*.test.ts'"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
